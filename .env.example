# ============================================================
# Smart Event Check-In — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Security — MUST change in production
SECRET_KEY=change-this-to-a-random-64-char-string-in-production

# Database
DATABASE_URL=sqlite:///./checkin.db

# ── GoHighLevel API ──────────────────────────────────────────
# Get your API key from: GHL → Settings → API Keys
GHL_API_KEY=your-ghl-api-key-here

# Your GHL Location / Sub-account ID
GHL_LOCATION_ID=your-ghl-location-id-here

# GHL API base URL (leave as default)
GHL_API_BASE_URL=https://services.leadconnectorhq.com

# GHL API version header (leave as default)
GHL_API_VERSION=2021-07-28

# ── Application ──────────────────────────────────────────────
# Public URL of this app (used in QR code email links)
# For local use: http://localhost:8000
# For VPS: https://your-domain.com
BASE_URL=http://localhost:8000

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# QR codes storage directory (relative to project root)
QR_CODE_DIR=static/qr_codes

# Session/token expiry in minutes (default 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480
